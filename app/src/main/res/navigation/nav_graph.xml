<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mainFragment">

    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.mycamera.fragment.CameraFragment"
        android:label="MainActivity"
        tools:layout="@layout/activity_main">

        <action
            android:id="@+id/action_mainFragment_to_previewFragment"
            app:destination="@id/previewFragment" />

    </fragment>

    <fragment
        android:id="@+id/previewFragment"
        android:name="com.example.mycamera.fragment.PreviewFragment"
        android:label="PreviewFragment"
        tools:layout="@layout/fragment_preview">

        <argument
            android:name="photoPath"
            app:argType="string" />

    </fragment>

</navigation>